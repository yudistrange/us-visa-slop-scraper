# ============================================
# US Visa Appointment Scheduler Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- US Visa System Credentials ---
# Your login email for ais.usvisa-info.com
USVISA_EMAIL=your-email@example.com

# Your login password
USVISA_PASSWORD=your-password

# Your schedule ID (found in the URL when viewing your appointment)
# e.g., https://ais.usvisa-info.com/en-ca/niv/schedule/12345678/...
SCHEDULE_ID=12345678

# --- Consulate Configuration ---
# Facility ID of the consulate you want to monitor (see facility_ids.md)
FACILITY_ID=95

# Country code as it appears in the URL path
# Examples: en-ca (Canada), en-in (India), en-gb (UK), en-mx (Mexico)
COUNTRY_CODE=en-ca

# --- Current Appointment ---
# Your current appointment date in YYYY-MM-DD format
# The tool will notify you when a date EARLIER than this is found
CURRENT_APPOINTMENT_DATE=2026-09-15

# --- Telegram Notifications ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your chat ID from @userinfobot
TELEGRAM_CHAT_ID=123456789

# --- Scheduler Settings ---
# How often to check for appointments (in minutes)
CHECK_INTERVAL_MINUTES=10

# Random jitter added to interval to avoid detection (in minutes)
CHECK_INTERVAL_JITTER_MINUTES=5

# Automatically reschedule to earlier date when found
# WARNING: Set to true only if you're sure you want auto-booking
AUTO_RESCHEDULE=false

# --- Advanced Settings (optional) ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum number of consecutive errors before alerting
MAX_CONSECUTIVE_ERRORS=5

# Browser headless mode (set to false for debugging)
HEADLESS=true
